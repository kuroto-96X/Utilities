@page "/bpm-tapper"

<PageTitle>Tap BPM</PageTitle>

<div class="tap-bpm-page">
    <!-- AdSense: Tap BPM - ここに広告コードを挿入 -->

    <div class="page-header text-center">
        <h1 class="page-title">Tap BPM</h1>
        <p class="page-desc text-muted">Tap the button to the beat to measure your BPM</p>
    </div>

    <div class="controls-section">
        <div class="bpm-display-area text-center">
            <div class="bpm-value">@(mainBpm.HasValue ? ((int)Math.Round(mainBpm.Value)).ToString() : "---")</div>
            <div class="bpm-label">BPM</div>
        </div>
    </div>

    <div class="tap-section">
        <button @key="tapAnimKey" class="tap-button @(isTapAnimating ? "tap-anim" : "")"
                @onpointerdown="OnPointerDown">
            <span class="tap-text">TAP</span>
        </button>
    </div>

    <div class="reset-section">
        <button class="reset-button @(isResetPressed ? "pressed" : "")"
                @onclick="OnReset"
                @onpointerdown="() => isResetPressed = true"
                @onpointerup="() => isResetPressed = false"
                @onpointerleave="() => isResetPressed = false"
                @onpointercancel="() => isResetPressed = false">Reset</button>
    </div>

    <div class="avg-label-section text-center text-muted small">@avgTapLabel</div>

    <div class="slider-wrapper">
        <div class="slider-spacer"></div>
        <div class="slider-inner">
            <input type="range" class="form-range"
                   min="0" max="100" step="1"
                   disabled="@(tapHistory.Count == 0)"
                   @bind="sliderValue" @bind:event="oninput" />
        </div>
    </div>

    @{
        var bpmPoints = tapHistory.Where(t => t.InstantBpm.HasValue).Select(t => t.InstantBpm!.Value).ToList();
        string inPolyline = "";
        string outPolyline = "";
        string mainBpmPath = "";
        int chartMinInt = 0, chartMaxInt = 0;
        double mainBpmLabelTopPx = -1;

        if (bpmPoints.Count >= 2)
        {
            double minB = bpmPoints.Min();
            double maxB = bpmPoints.Max();
            double bpmRange = Math.Max(maxB - minB, 10);
            double yMin = minB - bpmRange * 0.15;
            double yMax = maxB + bpmRange * 0.15;
            chartMinInt = (int)Math.Round(minB);
            chartMaxInt = (int)Math.Round(maxB);

            int svgW = 400, svgH = 80, padX = 8, padY = 8;
            double xStep = (double)(svgW - padX * 2) / (bpmPoints.Count - 1);

            var allPts = bpmPoints.Select((bpm, i) =>
            {
                double x = padX + i * xStep;
                double y = svgH - padY - (bpm - yMin) / (yMax - yMin) * (svgH - padY * 2);
                return $"{x:F1},{y:F1}";
            }).ToList();

            int n = Math.Max(1, (int)Math.Floor(bpmPoints.Count * effectiveSliderValue / 100.0));
            int splitIndex = bpmPoints.Count - n;

            if (splitIndex > 0)
                outPolyline = string.Join(" ", allPts.Take(splitIndex + 1));
            inPolyline = string.Join(" ", allPts.Skip(splitIndex));

            if (mainBpm.HasValue)
            {
                double my = svgH - padY - (mainBpm.Value - yMin) / (yMax - yMin) * (svgH - padY * 2);
                my = Math.Clamp(my, padY, svgH - padY);
                mainBpmPath = $"M{padX} {my:F1} L{svgW - padX} {my:F1}";
                mainBpmLabelTopPx = my;
            }
        }
    }
    @if (inPolyline != "")
    {
        <div class="chart-section">
            <div class="chart-wrapper">
                <div class="chart-y-labels">
                    <span>@chartMaxInt</span>
                    @if (mainBpmLabelTopPx >= 0)
                    {
                        <span class="chart-main-label" style="top: @(mainBpmLabelTopPx.ToString("F1"))px">
                            @((int)Math.Round(mainBpm!.Value))
                        </span>
                    }
                    <span>@chartMinInt</span>
                </div>
                <svg viewBox="0 0 400 80" preserveAspectRatio="none" class="bpm-chart">
                    @if (mainBpmPath != "")
                    {
                        <path d="@mainBpmPath" stroke="#dc3545" stroke-width="1.5" stroke-dasharray="4 3" fill="none" />
                    }
                    @if (outPolyline != "")
                    {
                        <polyline points="@outPolyline"
                                  fill="none" stroke="#adb5bd" stroke-width="1.5"
                                  stroke-linejoin="round" stroke-linecap="round" />
                    }
                    <polyline points="@inPolyline"
                              fill="none" stroke="#0d6efd" stroke-width="2.5"
                              stroke-linejoin="round" stroke-linecap="round" />
                </svg>
            </div>
        </div>
    }

    <div class="history-section">
        @if (tapHistory.Count == 0)
        {
        }
        else
        {
            <div class="table-responsive">
                <table class="table table-sm table-striped mb-0">
                    <thead class="table-dark">
                        <tr>
                            <th>#</th>
                            <th>Time</th>
                            <th>Interval (ms)</th>
                            <th>Instant BPM</th>
                        </tr>
                    </thead>
                    <tbody>
                        @{
                            int intervalCount = tapHistory.Count - 1;
                            int n = intervalCount > 0 ? Math.Max(1, (int)Math.Floor(intervalCount * effectiveSliderValue / 100.0)) : 0;
                            bool showDivider = intervalCount > 0 && n < intervalCount;
                            int dividerBeforeIndex = tapHistory.Count - n - 1;
                        }
                        @for (int i = tapHistory.Count - 1; i >= 0; i--)
                        {
                            if (showDivider && i == dividerBeforeIndex)
                            {
                                <tr class="range-divider"><td colspan="4"></td></tr>
                            }
                            var tap = tapHistory[i];
                            bool outOfRange = showDivider && i <= dividerBeforeIndex;
                            <tr class="@(outOfRange ? "out-of-range" : "")">
                                <td>@tap.Index</td>
                                <td>@tap.TimeDisplay</td>
                                <td>@(tap.IntervalMs.HasValue ? ((int)tap.IntervalMs.Value).ToString() : "-")</td>
                                <td>@(tap.InstantBpm.HasValue ? ((int)Math.Round(tap.InstantBpm.Value)).ToString() : "-")</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>

@code {
    private record TapRecord(int Index, DateTime Timestamp, double? IntervalMs, double? InstantBpm)
    {
        public string TimeDisplay => Timestamp.ToString("HH:mm:ss.fff");
    }

    private List<TapRecord> tapHistory = new();
    private int sliderValue = 0;
    private int effectiveSliderValue => 100 - sliderValue;
    private bool isResetPressed = false;
    private int tapAnimKey = 0;
    private bool isTapAnimating = false;
    private int _currentTapAnimKey = 0;

    private string avgTapLabel
    {
        get
        {
            int intervalCount = tapHistory.Count - 1;
            if (tapHistory.Count == 0) return "Tap the button to start";
            if (intervalCount <= 0) return "Tap again to measure BPM";
            int n = Math.Max(1, (int)Math.Floor(intervalCount * effectiveSliderValue / 100.0));
            return n == 1 ? "Instant BPM (1 tap)" : $"Averaging last {n} taps";
        }
    }

    private double? mainBpm
    {
        get
        {
            if (tapHistory.Count < 2) return null;

            var intervals = tapHistory
                .Skip(1)
                .Select(t => t.IntervalMs!.Value)
                .ToList();

            int n = Math.Max(1, (int)Math.Floor(intervals.Count * effectiveSliderValue / 100.0));
            var recent = intervals.TakeLast(n).ToList();
            return 60000.0 / recent.Average();
        }
    }

    private async Task OnPointerDown()
    {
        tapAnimKey++;
        _currentTapAnimKey = tapAnimKey;
        int myKey = tapAnimKey;
        isTapAnimating = true;
        OnTap();
        await Task.Delay(350);
        if (_currentTapAnimKey == myKey)
        {
            isTapAnimating = false;
            StateHasChanged();
        }
    }

    private void OnTap()
    {
        var now = DateTime.Now;
        double? interval = null;
        double? instantBpm = null;

        if (tapHistory.Count > 0)
        {
            interval = (now - tapHistory[^1].Timestamp).TotalMilliseconds;
            instantBpm = 60000.0 / interval.Value;
        }

        tapHistory.Add(new TapRecord(tapHistory.Count + 1, now, interval, instantBpm));
    }

    private void OnReset() => tapHistory.Clear();
}
